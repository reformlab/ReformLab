{
  "$schema": "./schema/workflow.schema.json",
  "description": "Multi-scenario batch analysis for sensitivity testing across different carbon tax rate trajectories",
  "name": "batch_sensitivity_analysis",
  "version": "1.0",
  "data_sources": {
    "emission_factors": "default",
    "population": "synthetic_french_2024"
  },
  "outputs": [
    {
      "by": ["income_decile", "scenario"],
      "type": "distributional_indicators"
    },
    {
      "format": "parquet",
      "path": "outputs/sensitivity_panel.parquet",
      "type": "panel_export"
    },
    {
      "format": "csv",
      "path": "outputs/scenario_comparison.csv",
      "type": "comparison_table"
    }
  ],
  "run_config": {
    "output_format": "parquet",
    "projection_years": 15,
    "start_year": 2025
  },
  "scenarios": [
    {"baseline": "carbon_tax_flat_44"},
    {"reform_low": "carbon_tax_flat_30"},
    {"reform_medium": "carbon_tax_flat_60"},
    {"reform_high": "carbon_tax_flat_100"},
    {"reform_progressive": "carbon_tax_progressive_trajectory"}
  ]
}

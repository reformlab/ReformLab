---

<section id="early-access" class="relative bg-paper py-24 lg:py-32 overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-rule"></div>

  <!-- Subtle dot grid bg -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, var(--color-ink) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <div class="reveal">
      <!-- Quote -->
      <blockquote class="mb-10">
        <p class="font-sans text-3xl lg:text-4xl font-bold text-ink leading-snug">
          "The next time someone asks <em class="text-cta not-italic">'who does this policy actually help?'</em> — they'll be able to&nbsp;answer."
        </p>
      </blockquote>

      <!-- Values line -->
      <p class="text-lg text-slate-mid font-medium mb-12">
        Open-source. Open-data-first. France and Europe.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:contact@reform-lab.eu" class="btn-primary !bg-ink hover:!bg-ink-light text-lg">
          Get Early Access
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" class="ml-1">
            <path d="M 4 9 L 13 9 M 10 5 L 14 9 L 10 13"/>
          </svg>
        </a>
        <a href="https://github.com/reformlab/reformlab" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3.5 border border-ink/15 rounded-md text-ink font-semibold hover:bg-ink/[0.04] transition-all duration-300 text-lg">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.477 0 10c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0110 4.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.163 20 14.418 20 10c0-5.523-4.477-10-10-10z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Contact -->
      <p class="mt-10 text-slate-mid">
        Questions? <a href="mailto:contact@reform-lab.eu" class="text-cta hover:text-emerald-400 underline underline-offset-4 decoration-emerald-500/30 hover:decoration-emerald-500 transition-colors">contact@reform-lab.eu</a>
      </p>
    </div>
  </div>
</section>

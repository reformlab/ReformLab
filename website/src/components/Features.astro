---
const features = [
  {
    title: "Open Data Pipeline",
    subtitle: "Connect to European data sources without the pain",
    description: "Pre-built connectors for INSEE, Eurostat, and EU-SILC. Automatic data harmonization, synthetic population generation from public marginals, and full traceability of every transformation step.",
    size: "large",
    accent: "teal",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 4 7 C 4 5 8 3 14 3 S 24 5 24 7"/><ellipse cx="14" cy="7" rx="10" ry="4"/><path d="M 4 7 v 7 c 0 2 4 4 10 4 s 10 -2 10 -4 V 7"/><path d="M 4 14 v 7 c 0 2 4 4 10 4 s 10 -2 10 -4 v -7"/></svg>`
  },
  {
    title: "Scenario Templates",
    subtitle: "Define policies in minutes, not weeks",
    description: "Carbon tax, energy subsidies, feebates, targeted rebates, social transfers. YAML-based templates with documented parameters. Adjust in the GUI or a text editor.",
    size: "small",
    accent: "amber",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="3" width="18" height="22" rx="2"/><path d="M 9 9 h 10 M 9 13 h 7 M 9 17 h 9"/></svg>`
  },
  {
    title: "Dynamic Orchestrator",
    subtitle: "Multi-year projections with real state tracking",
    description: "Run 10+ year projections with year-to-year state transitions. Vintage tracking for heating systems, vehicles, buildings. Cumulative indicators across the full projection horizon.",
    size: "large",
    accent: "amber",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="14" r="4"/><circle cx="21" cy="7" r="4"/><circle cx="21" cy="21" r="4"/><path d="M 11 12 L 17 8 M 11 16 L 17 20"/></svg>`
  },
  {
    title: "Scenario Comparison",
    subtitle: "Test policy variants side by side",
    description: "Side-by-side indicators, diff views, parameter sweeps, and winners-and-losers tables. Define 9 scenario combinations and compare them all at once.",
    size: "small",
    accent: "teal",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="9" height="18" rx="1.5"/><rect x="16" y="5" width="9" height="18" rx="1.5"/><path d="M 12 14 h 4" stroke-dasharray="2 2"/></svg>`
  },
  {
    title: "Indicators & Analysis",
    subtitle: "From raw numbers to decision-ready outputs",
    description: "Distributional impact, welfare indicators, fiscal analysis, policy performance metrics, and geographic breakdowns. Every indicator traces back to its source assumptions.",
    size: "small",
    accent: "amber",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="17" width="4" height="8" rx="1"/><rect x="9" y="12" width="4" height="13" rx="1"/><rect x="15" y="7" width="4" height="18" rx="1"/><rect x="21" y="3" width="4" height="22" rx="1"/></svg>`
  },
  {
    title: "Run Manifests",
    subtitle: "Every run is traceable. Every result is reproducible.",
    description: "Automatic immutable manifests documenting engine version, data hashes, all parameters, population assumptions. Re-run any analysis on any machine with identical results.",
    size: "small",
    accent: "teal",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 14 3 L 25 9 v 10 L 14 25 L 3 19 V 9 Z"/><path d="M 14 25 v -10 M 14 15 L 3 9 M 14 15 L 25 9"/></svg>`
  },
  {
    title: "No-Code GUI + Python API",
    subtitle: "Two modes, one engine",
    description: "The GUI is the primary interface — select data, configure scenarios, run simulations, compare results, all in the browser. For researchers: full Python API with Jupyter integration, DataFrame access, and reproducible notebook workflows. Both share the same engine.",
    size: "full",
    accent: "amber",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="24" height="16" rx="2"/><path d="M 2 9 h 24"/><circle cx="5" cy="6.5" r="0.75" fill="currentColor"/><circle cx="8" cy="6.5" r="0.75" fill="currentColor"/><path d="M 7 15 l 3 -3 -3 -3 M 12 16 h 5"/><path d="M 8 24 h 12"/></svg>`
  }
];
---

<section id="features" class="relative bg-paper-warm py-24 lg:py-32">
  <div class="absolute top-0 left-0 right-0 h-px bg-rule"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-16 lg:mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-amber"></div>
        <span class="text-amber font-medium text-sm tracking-widest uppercase">Capabilities</span>
      </div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl lg:text-5xl font-bold text-ink leading-tight">
        What you get
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 reveal-stagger">
      {features.map((feature) => (
        <div class={`reveal group relative rounded-xl border border-rule/60 bg-white p-8 lg:p-10 transition-all duration-500 hover:shadow-lg hover:shadow-ink/[0.04] hover:-translate-y-0.5
          ${feature.size === 'large' ? 'md:col-span-2 lg:col-span-2' : ''}
          ${feature.size === 'full' ? 'md:col-span-2 lg:col-span-3' : ''}
        `}>
          {/* Accent line at top */}
          <div class={`absolute top-0 left-8 right-8 h-px ${feature.accent === 'amber' ? 'bg-amber/30' : 'bg-teal/30'}`}></div>

          <div class={`w-12 h-12 rounded-lg flex items-center justify-center mb-6 ${feature.accent === 'amber' ? 'bg-amber-soft text-amber' : 'bg-teal-soft text-teal'}`} set:html={feature.icon} />

          <h3 class="font-[family-name:var(--font-display)] text-xl lg:text-2xl font-semibold text-ink mb-2">
            {feature.title}
          </h3>

          <p class={`text-sm font-medium mb-4 ${feature.accent === 'amber' ? 'text-amber' : 'text-teal'}`}>
            {feature.subtitle}
          </p>

          <p class="text-slate leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

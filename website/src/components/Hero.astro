---
---

<section class="relative min-h-[100vh] flex items-center mesh-gradient overflow-hidden">
  <!-- Animated dot grid overlay -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, rgba(250,248,245,0.8) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- Decorative abstract chart — top right -->
  <div class="absolute top-24 right-8 lg:right-16 opacity-[0.08] pointer-events-none select-none" aria-hidden="true">
    <svg width="320" height="280" viewBox="0 0 320 280" fill="none">
      <!-- Stylized bar chart fragment -->
      <rect x="20" y="180" width="28" height="80" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="60" y="140" width="28" height="120" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="100" y="100" width="28" height="160" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="140" y="60" width="28" height="200" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="180" y="120" width="28" height="140" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="220" y="80" width="28" height="180" rx="2" fill="currentColor" class="text-paper"/>
      <rect x="260" y="150" width="28" height="110" rx="2" fill="currentColor" class="text-paper"/>
      <!-- Distribution curve -->
      <path d="M 34 175 C 80 170, 100 60, 154 55 C 200 50, 240 75, 274 145" stroke="currentColor" class="text-amber-glow" stroke-width="2" fill="none" opacity="0.5"/>
    </svg>
  </div>

  <!-- Decorative flow lines — bottom left -->
  <div class="absolute bottom-16 left-8 lg:left-16 opacity-[0.06] pointer-events-none select-none" aria-hidden="true">
    <svg width="260" height="200" viewBox="0 0 260 200" fill="none">
      <path d="M 0 100 C 60 80, 100 40, 140 60 S 200 120, 260 80" stroke="currentColor" class="text-paper" stroke-width="1.5" fill="none"/>
      <path d="M 0 120 C 60 100, 100 60, 140 80 S 200 140, 260 100" stroke="currentColor" class="text-paper" stroke-width="1" fill="none"/>
      <path d="M 0 140 C 60 120, 100 80, 140 100 S 200 160, 260 120" stroke="currentColor" class="text-paper" stroke-width="0.75" fill="none"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-28 pb-20 lg:pt-40 lg:pb-32">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <div class="reveal flex items-center gap-3 mb-8">
        <div class="h-px w-12 bg-amber"></div>
        <span class="text-amber font-medium text-sm tracking-widest uppercase">Open-source policy analysis</span>
      </div>

      <!-- Headline -->
      <h1 class="reveal font-[family-name:var(--font-display)] text-5xl sm:text-6xl lg:text-7xl font-bold text-paper leading-[1.08] mb-8">
        See who your policy
        <span class="relative inline-block">
          actually
          <svg class="absolute -bottom-1 left-0 w-full" height="8" viewBox="0 0 200 8" preserveAspectRatio="none">
            <path d="M 0 6 C 40 2, 80 2, 100 4 C 120 6, 160 4, 200 2" stroke="var(--color-amber)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        helps.
      </h1>

      <!-- Subheadline -->
      <p class="reveal text-xl lg:text-2xl text-slate-light leading-relaxed mb-12 max-w-2xl font-light">
        Connect open data to policy models. See distributional impact. No coding, no&nbsp;waiting.
      </p>

      <!-- CTAs -->
      <div class="reveal flex flex-col sm:flex-row gap-4">
        <a href="#early-access" class="btn-primary text-lg">
          Get Early Access
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" class="ml-1">
            <path d="M 4 9 L 13 9 M 10 5 L 14 9 L 10 13"/>
          </svg>
        </a>
        <a href="#how-it-works" class="btn-secondary text-lg">
          See How It Works
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
      <span class="text-paper text-xs tracking-widest uppercase font-medium">Scroll</span>
      <div class="w-5 h-9 border border-paper/40 rounded-full flex justify-center pt-2">
        <div class="w-1 h-2.5 bg-paper/60 rounded-full animate-bounce"></div>
      </div>
    </div>
  </div>
</section>

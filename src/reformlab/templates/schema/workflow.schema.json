{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reformlab.io/schemas/workflow.schema.json",
  "title": "ReformLab Workflow Configuration",
  "description": "Schema for ReformLab workflow configuration files that define complete policy analysis workflows.",
  "type": "object",
  "required": ["name", "version", "scenarios"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE validation support."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow identifier. Must be unique within the project."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Schema version for migration compatibility (e.g., '1.0')."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the workflow purpose."
    },
    "data_sources": {
      "type": "object",
      "description": "Data source references for population and emission factors.",
      "properties": {
        "population": {
          "type": "string",
          "description": "Registry reference or path to population data source."
        },
        "emission_factors": {
          "type": "string",
          "default": "default",
          "description": "Registry reference or path to emission factors data source."
        }
      },
      "additionalProperties": false
    },
    "evidence_metadata": {
      "type": "object",
      "description": "Evidence model metadata for data sources (Story 21.8 / AC1). Classifies data sources by origin, access_mode, trust_status, and data_class.",
      "properties": {
        "population": {
          "type": "object",
          "description": "Evidence metadata for population data source.",
          "properties": {
            "asset_id": {
              "type": "string",
              "description": "Unique identifier for the asset (e.g., 'fr-synthetic-2024')."
            },
            "name": {
              "type": "string",
              "description": "Human-readable name of the asset."
            },
            "origin": {
              "type": "string",
              "enum": ["open-official", "synthetic-public", "synthetic-internal", "restricted"],
              "description": "Where the asset comes from."
            },
            "access_mode": {
              "type": "string",
              "enum": ["bundled", "fetched", "deferred-user-connector"],
              "description": "How ReformLab obtains the asset."
            },
            "trust_status": {
              "type": "string",
              "enum": ["production-safe", "exploratory", "demo-only", "validation-pending", "not-for-public-inference"],
              "description": "What can be claimed about the asset."
            },
            "data_class": {
              "type": "string",
              "enum": ["structural", "exogenous", "calibration", "validation"],
              "description": "The role of the data in the evidence taxonomy."
            },
            "note": {
              "type": "string",
              "description": "Optional notes about the data source."
            },
            "provider": {
              "type": "string",
              "description": "Data provider identifier (e.g., 'insee', 'ademe')."
            }
          },
          "required": ["asset_id", "name", "origin", "access_mode", "trust_status", "data_class"],
          "additionalProperties": false
        },
        "emission_factors": {
          "type": "object",
          "description": "Evidence metadata for emission factors data source.",
          "properties": {
            "asset_id": {
              "type": "string",
              "description": "Unique identifier for the asset."
            },
            "name": {
              "type": "string",
              "description": "Human-readable name of the asset."
            },
            "origin": {
              "type": "string",
              "enum": ["open-official", "synthetic-public", "synthetic-internal", "restricted"],
              "description": "Where the asset comes from."
            },
            "access_mode": {
              "type": "string",
              "enum": ["bundled", "fetched", "deferred-user-connector"],
              "description": "How ReformLab obtains the asset."
            },
            "trust_status": {
              "type": "string",
              "enum": ["production-safe", "exploratory", "demo-only", "validation-pending", "not-for-public-inference"],
              "description": "What can be claimed about the asset."
            },
            "data_class": {
              "type": "string",
              "enum": ["structural", "exogenous", "calibration", "validation"],
              "description": "The role of the data in the evidence taxonomy."
            },
            "provider": {
              "type": "string",
              "description": "Data provider identifier."
            },
            "note": {
              "type": "string",
              "description": "Optional notes about the data source."
            }
          },
          "required": ["asset_id", "name", "origin", "access_mode", "trust_status", "data_class"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "description": "List of scenario references for the workflow.",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Plain scenario reference (registry name or name@version)."
          },
          {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "description": "Role-based scenario reference (e.g., {baseline: 'scenario-name'}).",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    },
    "run_config": {
      "type": "object",
      "description": "Orchestrator run configuration settings.",
      "properties": {
        "projection_years": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10,
          "description": "Number of years to project the analysis."
        },
        "start_year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2200,
          "default": 2025,
          "description": "Starting year for the projection."
        },
        "output_format": {
          "type": "string",
          "enum": ["csv", "parquet", "json", "yaml"],
          "default": "csv",
          "description": "Default output format for results."
        }
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "array",
      "description": "Requested output configurations for the workflow.",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["distributional_indicators", "comparison_table", "panel_export", "summary_report"],
            "description": "Type of output to generate."
          },
          "by": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Grouping dimensions for the output."
              },
              {
                "type": "string",
                "description": "Single grouping dimension."
              }
            ]
          },
          "format": {
            "type": "string",
            "enum": ["csv", "parquet", "json", "yaml"],
            "description": "Output format for this specific output."
          },
          "path": {
            "type": "string",
            "description": "Output file path for this output."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

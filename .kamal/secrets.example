#!/bin/sh
# Copy this file to .kamal/secrets and fill in real values.
# .kamal/secrets is gitignored — never commit it.
# This file must be executable: chmod +x .kamal/secrets

echo "KAMAL_REGISTRY_PASSWORD=ghp_your_token_here"
echo "REFORMLAB_PASSWORD=change_me_to_a_strong_password"
echo "HETZNER_IP=your_server_ip_here"

# Copy this file to .kamal/secrets and fill in real values.
# .kamal/secrets is gitignored — never commit it.

# GitHub Container Registry token (personal access token with write:packages scope)
KAMAL_REGISTRY_PASSWORD=ghp_your_token_here

# Shared password for colleague access to the web app
REFORMLAB_PASSWORD=change_me_to_a_strong_password

# Production server IP address (Hetzner)
HETZNER_IP=your_server_ip_here

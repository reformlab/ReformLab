{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Dev Server",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && cd frontend && nvm use && npm run dev -- --host 127.0.0.1 --port 4173",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^> reformlab-frontend@",
          "endsPattern": "ready in .*ms"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "group": "build"
    },
    {
      "label": "Backend: API Server",
      "type": "shell",
      "command": "uv run --extra server uvicorn reformlab.server.app:create_app --factory --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "REFORMLAB_PASSWORD": "local"
        },
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^INFO:",
          "endsPattern": "Application startup complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "Dev: Full Stack",
      "dependsOn": [
        "Backend: API Server",
        "Frontend: Dev Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "AI: Check Usage (Claude/Codex/Gemini)",
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && source \"$HOME/.nvm/nvm.sh\" && nvm use 22 >/dev/null; python3 scripts/check_ai_usage.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "AI: Check Usage + Open Dashboards",
      "type": "shell",
      "command": "[ -s \"$HOME/.nvm/nvm.sh\" ] && source \"$HOME/.nvm/nvm.sh\" && nvm use 22 >/dev/null; python3 scripts/check_ai_usage.py --open-dashboards",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "BMAD: Test Run (Cheap + Verbose)",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && nvm use 22 && /Users/lucas/Workspace/bmad-assist/.venv/bin/bmad-assist run -c bmad-assist-test.yaml -e ${input:epicNumber} -v --debug --full-stream --plain",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "bmad-assist-test",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*bmad-assist.*",
          "endsPattern": "^$NEVER_MATCH$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "BMAD: Run Epic",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && nvm use 22 && (git checkout epic-${input:epicNumber} 2>/dev/null || git checkout -b epic-${input:epicNumber} master) && /Users/lucas/Workspace/bmad-assist/.venv/bin/bmad-assist run -e ${input:epicNumber} -g -v --skip-story-prompts",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "bmad-assist",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*bmad-assist.*",
          "endsPattern": "^$NEVER_MATCH$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "epicNumber",
      "description": "Which epic to run? (e.g. 9)",
      "type": "promptString",
      "default": "9"
    }
  ]
}

{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Dev Server",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && cd frontend && nvm use && npm run dev -- --host 127.0.0.1 --port 4173",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^> reformlab-frontend@",
          "endsPattern": "ready in .*ms"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "group": "build"
    },
    {
      "label": "Backend: API Server",
      "type": "shell",
      "command": "uv run --extra server uvicorn reformlab.server.app:create_app --factory --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "REFORMLAB_PASSWORD": "local"
        },
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^INFO:",
          "endsPattern": "Application startup complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "Dev: Full Stack",
      "dependsOn": [
        "Backend: API Server",
        "Frontend: Dev Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CI: Sync Dependencies",
      "type": "shell",
      "command": "uv sync --locked --all-extras --dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Ruff",
      "type": "shell",
      "command": "uv run ruff check src tests",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Mypy",
      "type": "shell",
      "command": "uv run mypy src",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Pytest + Coverage",
      "type": "shell",
      "command": "uv run pytest --cov=src/reformlab --cov-report=term-missing tests/",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Notebook Quickstart",
      "type": "shell",
      "command": "uv run pytest --nbmake notebooks/quickstart.ipynb -v",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Notebook Advanced",
      "type": "shell",
      "command": "uv run marimo export html notebooks/advanced.py --no-include-code -o /dev/null",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "Marimo: Advanced Notebook",
      "type": "shell",
      "command": "uv run marimo edit notebooks/advanced.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*marimo",
          "endsPattern": "URL"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "CI: Notebook Population Example",
      "type": "shell",
      "command": "uv run pytest --nbmake notebooks/population-french-household-example.ipynb -v",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "CI: Full Local (Mirror GitHub)",
      "dependsOn": [
        "CI: Sync Dependencies",
        "CI: Ruff",
        "CI: Mypy",
        "CI: Pytest + Coverage",
        "CI: Notebook Quickstart",
        "CI: Notebook Advanced",
        "CI: Notebook Population Example"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "API: Quick Workflow Smoke Test",
      "type": "shell",
      "command": "uv run python examples/api/api_smoke_test.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "REFORMLAB_API_BASE_URL": "http://127.0.0.1:8000",
          "REFORMLAB_API_PASSWORD": "local"
        },
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "API: Start Backend + Smoke Test",
      "type": "shell",
      "command": "set -euo pipefail; REFORMLAB_PASSWORD=local uv run --extra server uvicorn reformlab.server.app:create_app --factory --port 8011 >/tmp/reformlab-api-smoke.log 2>&1 & PID=$!; trap 'kill $PID >/dev/null 2>&1 || true' EXIT; for i in $(seq 1 120); do curl -fs http://127.0.0.1:8011/api/openapi.json >/dev/null 2>&1 && break; sleep 0.25; done; REFORMLAB_API_BASE_URL=http://127.0.0.1:8011 REFORMLAB_API_PASSWORD=local uv run python examples/api/api_smoke_test.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "BMAD: Update bmad-assist",
      "type": "shell",
      "command": "cd /Users/lucas/Workspace/bmad-assist && git pull && uv sync",
      "options": {
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "BMAD: Run Epic",
      "type": "shell",
      "command": "set -o pipefail && source ~/.nvm/nvm.sh && nvm use 22 && (git checkout epic-${input:epicNumber} 2>/dev/null || git checkout -b epic-${input:epicNumber} master) && mkdir -p .bmad-assist/logs && export BMAD_LOGFILE=.bmad-assist/logs/epic-${input:epicNumber}-$(date +%Y%m%dT%H%M%S).log && caffeinate -s /Users/lucas/Workspace/bmad-assist/.venv/bin/bmad-assist run -e ${input:epicNumber} -g -v -n --skip-story-prompts 2>&1 | tee \"$BMAD_LOGFILE\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Website: Dev Server (localhost:4321)",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && cd website && nvm use && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*astro",
          "endsPattern": "localhost"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "Docs: Install Dependencies",
      "type": "shell",
      "command": "uv sync --group docs",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Docs: Serve (localhost:8100)",
      "type": "shell",
      "command": "uv run --group docs mkdocs serve --dev-addr 127.0.0.1:8100",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^INFO\\s+-\\s+Building documentation",
          "endsPattern": "Serving on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "Docs: Build Static Site",
      "type": "shell",
      "command": "uv run --group docs mkdocs build",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "epicNumber",
      "description": "Which epic to run? (e.g. 9)",
      "type": "promptString",
      "default": "9"
    }
  ]
}
